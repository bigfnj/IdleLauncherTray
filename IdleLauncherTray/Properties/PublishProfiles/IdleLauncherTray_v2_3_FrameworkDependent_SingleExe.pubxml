<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <TargetFramework>net10.0-windows</TargetFramework>
    <PublishProtocol>FileSystem</PublishProtocol>
    <PublishDir>bin\Publish\win-x64-framework-dependent-singlefile\</PublishDir>
    <PublishUrl>bin\Publish\win-x64-framework-dependent-singlefile\</PublishUrl>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <UseAppHost>true</UseAppHost>
    <PublishSingleFile>true</PublishSingleFile>
    <!-- Compression must stay disabled for framework-dependent single-file publish. -->
    <EnableCompressionInSingleFile>false</EnableCompressionInSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <DeleteExistingFiles>true</DeleteExistingFiles>
  </PropertyGroup>
</Project>
